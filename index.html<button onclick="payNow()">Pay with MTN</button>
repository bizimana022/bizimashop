<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Bizima Shop</title>
  <style>
    body { font-family: Arial; margin:0; background:#f4f4f4; }
    header { background:#1976d2; color:white; text-align:center; padding:20px; }
    nav { background:#111; padding:10px; text-align:center; }
    nav a { color:white; margin:10px; text-decoration:none; }
    .products { display:flex; gap:20px; padding:20px; justify-content:center; }
    .card { background:white; padding:15px; border-radius:10px; text-align:center; }
    button { background:#1976d2; color:white; border:none; padding:10px; cursor:pointer; }
  </style>
</head>
<body>

<header>
  <h1>🛒 Bizima Shop</h1>
  <p>Online Store</p>
</header>

<nav>
  <a href="#">Home</a>
</nav>

<section class="products">

  <div class="card">
    <h3>T-Shirt</h3>
    <p>10,000 RWF</p>
    <button onclick="add()">Add</button>
  </div>

  <div class="card">
    <h3>Shoes</h3>
    <p>25,000 RWF</p>
    <button onclick="add()">Add</button>
  </div>

</section>

<script>
function add(){
  alert("Added to cart 🛒");
}
</script>

</body>
</html>
