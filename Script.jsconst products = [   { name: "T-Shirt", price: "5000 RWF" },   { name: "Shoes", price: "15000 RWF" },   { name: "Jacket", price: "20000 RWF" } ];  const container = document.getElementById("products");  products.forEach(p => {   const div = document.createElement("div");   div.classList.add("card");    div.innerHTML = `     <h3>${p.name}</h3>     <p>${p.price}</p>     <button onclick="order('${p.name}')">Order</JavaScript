async function payNow() {
  const phone = prompt("Shyiramo nimero yawe (2507...)");
  const amount = 1000;

  const res = await fetch("http://localhost:3000/pay", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ phone, amount })
  });

  const data = await res.json();
  alert(data.message);
}
